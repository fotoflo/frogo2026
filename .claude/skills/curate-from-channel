  const { data: ch } = await supabase
    .from('channels')
    .upsert({ name: '...', slug: '...', description: '...', icon: '📼' }, { onConflict: 'slug' })
    .select('id').single();
  const videos = [ /* { youtube_id, title, description, duration_seconds, position } */ ];
  await supabase.from('videos').upsert(
    videos.map(v => ({
